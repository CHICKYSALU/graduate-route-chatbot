# ── Required ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Google Sheets lead logging ──────────────────────────────────────
# Leave both blank to disable. See README for setup steps.
GOOGLE_SHEETS_CREDENTIALS_FILE=/path/to/service-account-credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ── Optional: Gmail confirmation email ────────────────────────────────────────
# Leave both blank to disable. See README for Gmail App Password setup steps.
SMTP_EMAIL=you@gmail.com
SMTP_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
